# Auto detect text files and normalize line endings to LF
* text=auto

# C# files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf

# Razor/HTML
*.cshtml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# JSON/Config
*.json text eol=lf
*.xml text eol=lf
*.config text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
