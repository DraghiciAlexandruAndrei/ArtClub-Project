
@model List<ArtClub.Models.ViewModels.InvitationInboxViewModel>

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-envelope-paper"></i> Invitațiile Mele</h2>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success">@TempData["StatusMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Momentan nu ai nicio invitație nouă.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var inv in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@inv.EventTitle</h5>
                            <h6 class="card-subtitle mb-2 text-muted">De la: @inv.OrganizerName</h6>
                            <p class="card-text text-truncate">@inv.Description</p>
                            <p class="small text-secondary">
                                <i class="bi bi-calendar-event"></i> @inv.EventDate.ToString("dd MMM yyyy, HH:mm")
                            </p>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-between">
                            <form asp-action="Accept" asp-controller="Invitation" method="post">
                                <input type="hidden" name="id" value="@inv.InvitationId" />
                                <button type="submit" class="btn btn-success btn-sm">
                                    <i class="bi bi-check-lg"></i> Acceptă
                                </button>
                            </form>

                            <form asp-action="Decline" asp-controller="Invitation" method="post">
                                <input type="hidden" name="id" value="@inv.InvitationId" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-x-lg"></i> Refuză
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>