@model ArtClub.Models.ViewModels.Resource.ResourceReservationDatesReportViewModel

@{
    ViewData["Title"] = "Reservation Dates Report";
}

<h1>Reservation Dates Report</h1>

<form asp-action="ReservationDatesReport" method="get" class="row g-2 my-3">
    <div class="col-md-4">
        <label class="form-label">Resource name</label>
        <input type="text" name="name" value="@Model.ResourceName" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Start date</label>
        <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">End date</label>
        <input type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-auto d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Generate report</button>
    </div>
</form>

@if (Model.Reservations.Any())
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Start time</th>
                <th>End time</th>
                <th>Event</th>
                <th>Status</th>
                <th>Admin override</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var reservation in Model.Reservations)
        {
            <tr>
                <td>@reservation.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@reservation.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(reservation.Event?.Title ?? "No linked event")</td>
                <td>@reservation.Status</td>
                <td>@(reservation.IsAdminOverride ? "Yes" : "No")</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No reservations found for the selected resource and period.</div>
}

<a asp-action="Index" class="btn btn-secondary">← Back to resources</a>
