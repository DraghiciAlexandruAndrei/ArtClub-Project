@using Microsoft.AspNetCore.Identity
@using ArtClub.Models.Entities
@using ArtClub.Models.Enums
@using ArtClub.Services.Interfaces
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@inject IEventService EventService

@{
    ViewData["Title"] = SignInManager.IsSignedIn(User) ? "Dashboardul Meu" : "Acasă";

    User currentUser = null;
    List<Event> myEvents = new List<Event>();

    int maxEventsLimit = 1; // Implicit pentru utilizator normal / External
    bool isUnlimited = false;

    if (SignInManager.IsSignedIn(User))
    {
        currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            // Preluăm doar evenimentele create de utilizatorul curent
            var allEvents = await EventService.GetAllEventsAsync();
            myEvents = allEvents.Where(e => e.OrganizerId == currentUser.Id).OrderByDescending(e => e.Id).ToList();

            // Stabilim limita exactă în funcție de rolul din baza de date
            if (currentUser.Role == UserRole.Admin)
            {
                isUnlimited = true;
            }
            else if (currentUser.Role == UserRole.Member)
            {
                maxEventsLimit = 5;
            }
            else
            {
                maxEventsLimit = 1; // User normal / External
            }
        }
    }
}

@if (!SignInManager.IsSignedIn(User))
{
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold text-primary"><i class="bi bi-palette2"></i> Art Club Management System</h1>
            <p class="col-md-8 fs-5 text-muted">A web application for members, resources, events, reservations, and financial reporting.</p>
            <div class="d-flex gap-2 mt-4">
                <a class="btn btn-primary btn-lg px-4" asp-controller="Account" asp-action="Register">Create account</a>
                <a class="btn btn-outline-secondary btn-lg px-4" asp-controller="Account" asp-action="Login">Sign in</a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title fw-bold"><i class="bi bi-people text-primary"></i> Members</h5>
                    <p class="card-text text-muted small">Registration, login, and profile access.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title fw-bold"><i class="bi bi-building text-primary"></i> Resources</h5>
                    <p class="card-text text-muted small">Rooms, availability, and reservation calendar.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title fw-bold"><i class="bi bi-calendar-event text-primary"></i> Events</h5>
                    <p class="card-text text-muted small">Event creation, invitations, and attendance.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title fw-bold"><i class="bi bi-cash-coin text-primary"></i> Finance</h5>
                    <p class="card-text text-muted small">Income, expenses, and monthly reports.</p>
                </div>
            </div>
        </div>
    </div>
}
else if (currentUser != null)
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Salut, @currentUser.UserName!</h2>
            <p class="text-muted mb-0">Acesta este panoul tău de control personal din cadrul clubului.</p>
        </div>
        <div>
            <span class="badge bg-primary text-white p-2 shadow-sm fs-6">
                <i class="bi bi-person-check-fill"></i> Rol: @currentUser.Role.ToString()
            </span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 @(currentUser.IsMembershipActive ? "border-bottom border-success border-3" : "border-bottom border-warning border-3")">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-bold mb-3"><i class="bi bi-star"></i> Status Club</h6>
                    @if (currentUser.Role == UserRole.Admin)
                    {
                        <h3 class="text-danger fw-bold">Administrator</h3>
                        <p class="small text-muted mb-0">Control total asupra platformei.</p>
                    }
                    else if (currentUser.IsMembershipActive)
                    {
                        <h3 class="text-success fw-bold">Membru Activ</h3>
                        <p class="small text-muted mb-0">Beneficiezi de facilitățile și reducerile clubului.</p>
                    }
                    else
                    {
                        <h3 class="text-warning fw-bold">User Normal</h3>
                        <p class="small text-muted mb-0">Cont gratuit (fără abonament activ).</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 border-bottom border-primary border-3">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-bold mb-3"><i class="bi bi-calendar-plus"></i> Limită Evenimente</h6>
                    <h3 class="text-primary fw-bold">
                        @myEvents.Count / @(isUnlimited ? "Nelimitat" : maxEventsLimit.ToString())
                    </h3>
                    <p class="small text-muted mb-0">Evenimente create de tine din totalul permis.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            @if (!isUnlimited && myEvents.Count >= maxEventsLimit)
            {
                <div class="card shadow-sm border-0 h-100 bg-light text-dark border-bottom border-danger border-3">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                        <span class="text-danger fw-bold mb-1"><i class="bi bi-exclamation-octagon-fill"></i> Limită atinsă!</span>
                        <p class="small text-muted mb-2">Ai organizat deja numărul maxim de @maxEventsLimit evenimente permise.</p>
                        <button class="btn btn-secondary btn-sm w-100" disabled>
                            <i class="bi bi-slash-circle"></i> Creează blocat
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0 h-100 bg-primary text-white">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                        <h5 class="fw-bold mb-3">Vrei să organizezi ceva?</h5>
                        <a asp-controller="Event" asp-action="Create" class="btn btn-light text-primary fw-bold w-100 shadow-sm">
                            <i class="bi bi-plus-circle"></i> Creează Eveniment Nou
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-card-list text-primary me-2"></i> Evenimentele mele</h5>
            <span class="badge bg-light text-dark border">@myEvents.Count în listă</span>
        </div>
        <div class="card-body p-0">
            @if (myEvents.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-borderless align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Titlu Eveniment</th>
                                <th>Sală alocată</th>
                                <th>Data desfășurării</th>
                                <th class="text-end pe-4">Acțiuni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ev in myEvents)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@ev.Title</td>
                                    <td><span class="badge bg-light text-dark"><i class="bi bi-geo-alt"></i> @(ev.Resource?.Name ?? "Fără locație")</span></td>
                                    <td>
                                        <small class="text-muted">
                                            <i class="bi bi-clock"></i> @(ev.Reservation?.StartTime.ToString("dd MMM yyyy, HH:mm") ?? "-")
                                        </small>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Event" asp-action="Details" asp-route-title="@ev.Title" class="btn btn-sm btn-outline-primary">
                                            Detalii <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-calendar-x fs-1 d-block mb-3 text-secondary"></i>
                    <h5 class="fw-bold">Nu ai organizat niciun eveniment.</h5>
                    <p class="small">Lista ta este goală momentan. Când vei crea primul tău eveniment, el va apărea centralizat aici.</p>
                </div>
            }
        </div>
    </div>
}