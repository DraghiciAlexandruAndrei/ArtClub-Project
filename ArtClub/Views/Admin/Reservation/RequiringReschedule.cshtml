@model IEnumerable<ArtClub.Models.ViewModels.Reservation.ReservationStatusViewModel>

@{
    ViewData["Title"] = "Reservations Requiring Reschedule";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Reservations Requiring Reschedule</h1>
        <p class="text-muted mb-0">View all reservations that were overridden and require users to reschedule.</p>
    </div>
    <a asp-action="PendingOverrides" class="btn btn-secondary">View Pending Overrides</a>
</div>

@if (Model?.Any() == true)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Resource</th>
                    <th>Original Start Time</th>
                    <th>Original End Time</th>
                    <th>Status</th>
                    <th>Conflict Admin</th>
                    <th>Created</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reservation in Model)
                {
                    <tr>
                        <td>
                            <strong>@reservation.ResourceName</strong>
                        </td>
                        <td>@reservation.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@reservation.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <span class="@reservation.StatusBadgeClass">@reservation.StatusLabel</span>
                        </td>
                        <td>
                            @if (reservation.AdminOverrideById.HasValue)
                            {
                                <small class="text-muted">Admin ID: @reservation.AdminOverrideById</small>
                            }
                            else
                            {
                                <small class="text-muted">-</small>
                            }
                        </td>
                        <td>
                            @if (reservation.OverrideCreatedAt.HasValue)
                            {
                                <small class="text-muted">@reservation.OverrideCreatedAt.Value.ToString("dd.MM.yyyy HH:mm:ss")</small>
                            }
                        </td>
                        <td>
                            <a href="/Reservation/Reschedule/@reservation.ReservationId" class="btn btn-sm btn-outline-primary">
                                View User Page
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-info-circle display-6"></i>
        <p class="mt-3 mb-0">No reservations requiring reschedule at this time.</p>
    </div>
}
