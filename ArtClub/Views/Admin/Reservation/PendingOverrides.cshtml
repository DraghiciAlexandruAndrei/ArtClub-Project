@model IEnumerable<ArtClub.Models.ViewModels.Reservation.ReservationStatusViewModel>

@{
    ViewData["Title"] = "Pending Reservation Overrides";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Pending Reservation Overrides</h1>
        <p class="text-muted mb-0">Approve or reject admin override reservations that conflict with existing bookings.</p>
    </div>
    <a asp-action="RequiringReschedule" class="btn btn-secondary">View Requiring Reschedule</a>
</div>

@if (Model?.Any() == true)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Resource</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reservation in Model)
                {
                    <tr>
                        <td>
                            <strong>@reservation.ResourceName</strong>
                        </td>
                        <td>@reservation.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@reservation.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <span class="@reservation.StatusBadgeClass">@reservation.StatusLabel</span>
                        </td>
                        <td>@reservation.OverrideCreatedAt?.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td>
                            <form method="post" style="display:inline;">
                                @if (reservation.Status.ToString() == "PendingApproval")
                                {
                                    <button asp-action="ApprovePending" asp-route-reservationId="@reservation.ReservationId" 
                                            type="submit" class="btn btn-sm btn-success" 
                                            onclick="return confirm('Approve this override reservation?')">
                                        <i class="bi bi-check-circle"></i> Approve
                                    </button>
                                    <button asp-action="RejectPending" asp-route-reservationId="@reservation.ReservationId" 
                                            type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Reject this override reservation?')">
                                        <i class="bi bi-x-circle"></i> Reject
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted">No actions available</span>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-info-circle display-6"></i>
        <p class="mt-3 mb-0">No pending override reservations. All overrides have been processed.</p>
    </div>
}
